#include "qcom-ipq8065-smb208.dtsi"

#include <dt-bindings/input/input.h>

/ {
	model = "Synology RT2600AC";
	compatible = "synology,rt2600ac", "qcom,ipq8065-rt2600ac",
		     "qcom,ipq8065", "qcom,ipq806x";

	memory@0 {
		device_type = "memory";
		reg = <0x42000000 0x1e000000>;
	};

	aliases {
		mdio-gpio0 = &mdio0;
		sdcc1 = &sdcc1;
		serial0 = &gsbi4_serial;

		led-boot = &power;
		led-failsafe = &power;
		led-running = &power;
		led-upgrade = &power;
	};

	chosen {
		stdout-path = "serial0:115200n8";
		bootargs = "rootfstype=squashfs,ext4 rootwait noinitrd root=/dev/mmcblk0p5";
	};

	keys {
		compatible = "gpio-keys";
		pinctrl-0 = <&rt2600_button_pins>;
		pinctrl-names = "default";

		reset {
			label = "reset";
			gpios = <&qcom_pinmux 54 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <60>;
			wakeup-source;
		};

		wps {
			label = "wps";
			gpios = <&qcom_pinmux 65 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_WPS_BUTTON>;
			debounce-interval = <60>;
			wakeup-source;
		};

		wifi {
			label = "wifi";
			gpios = <&qcom_pinmux 53 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RFKILL>;
			debounce-interval = <60>;
			wakeup-source;
		};
	};

	leds {
		compatible = "gpio-leds";
		pinctrl-0 = <&rt2600_led_pins>;
		pinctrl-names = "default";

		internet {
			label = "white:internet";
			gpios = <&qcom_pinmux 64 GPIO_ACTIVE_HIGH>;
		};

		power: power {
			label = "white:power";
			gpios = <&qcom_pinmux 9 GPIO_ACTIVE_HIGH>;
			default-state = "keep";
		};

		wifi2g {
			label = "amber:wifi2g";
			gpios = <&qcom_pinmux 33 GPIO_ACTIVE_HIGH>;
		};

		wifi5g {
			label = "amber:wifi5g";
			gpios = <&qcom_pinmux 26 GPIO_ACTIVE_HIGH>;
		};
	};
};

&qcom_pinmux {
	rt2600_button_pins: rt2600-button-pins {
		mux {
			pins = "gpio53", "gpio54", "gpio65";
			function = "gpio";
			drive-strength = <2>;
			bias-pull-up;
		};
	};

	rt2600_led_pins: rt2600-led-pins {
		mux {
			pins = "gpio9", "gpio26", "gpio33", "gpio64";
			function = "gpio";
			drive-strength = <2>;
			bias-pull-down;
		};
	};

	rt2600_mdio0_pins: rt2600-mdio0-pins {
		clk {
			pins = "gpio1";
			input-disable;
		};
	};

	rt2600_rgmii2_pins: rt2600-rgmii2-pins {
		tx {
			pins = "gpio27", "gpio28", "gpio29",
			       "gpio30", "gpio31", "gpio32";
			input-disable;
		};
	};

	rt2600_spi_pins: rt2600-spi-pins {
		cs {
			pins = "gpio20";
			drive-strength = <12>;
		};
	};

	rt2600_usb0_pwr_en_pins: rt2600-usb0-pwr-en-pins {
		mux {
			pins = "gpio16", "gpio17";
			function = "gpio";
			drive-strength = <12>;
		};

		pwr {
			pins = "gpio17";
			bias-pull-down;
			output-high;
		};

		ovc {
			pins = "gpio16";
			bias-pull-up;
		};
	};

	rt2600_usb1_pwr_en_pins: rt2600-usb1-pwr-en-pins {
		mux {
			pins = "gpio14", "gpio15";
			function = "gpio";
			drive-strength = <12>;
		};

		pwr {
			pins = "gpio14";
			bias-pull-down;
			output-high;
		};

		ovc {
			pins = "gpio15";
			bias-pull-up;
		};
	};
};

&gsbi5 {
	qcom,mode = <GSBI_PROT_SPI>;
	status = "okay";

	spi4: spi@1a280000 {
		status = "okay";

		pinctrl-0 = <&rt2600_spi_pins>;
		pinctrl-names = "default";

		cs-gpios = <&qcom_pinmux 20 GPIO_ACTIVE_HIGH>;

		flash@0 {
			compatible = "mx25u6435f", "jedec,spi-nor";
			reg = <0>;
			spi-max-frequency = <51200000>;

			partitions {
				compatible = "qcom,smem-part";
			};
		};
	};
};

&mdio0 {
	status = "okay";

	pinctrl-0 = <&rt2600_mdio0_pins>;
	pinctrl-names = "default";

	phy0: ethernet-phy@0 {
		reg = <0>;
		qca,ar8327-initvals = <
			0x00004 0x7600000
			0x00008 0x1000000
			0x0000c 0x80
			0x000e4 0xaa545
			0x000e0 0xc74164de
			0x0007c 0x4e
			0x00094 0x4e
			0x00970 0x1e864443
			0x00974 0x000001c6
			0x00978 0x19008643
			0x0097c 0x000001c6
			0x00980 0x19008643
			0x00984 0x000001c6
			0x00988 0x19008643
			0x0098c 0x000001c6
			0x00990 0x19008643
			0x00994 0x000001c6
			0x00998 0x1e864443
			0x0099c 0x000001c6
			0x009a0 0x1e864443
			0x009a4 0x000001c6
		>;
		qca,ar8327-vlans = <
			0x1 0x5e
			0x2 0x21
		>;
	};

	phy4: ethernet-phy@4 {
		reg = <4>;
		qca,ar8327-initvals = <
			0x000e4 0x6a545
			0x0000c 0x80
		>;
	};
};

&gmac1 {
	status = "okay";
	phy-mode = "rgmii";
	qcom,id = <1>;
	qcom,phy_mdio_addr = <4>;
	qcom,poll_required = <0>;
	qcom,rgmii_delay = <1>;
	qcom,phy_mii_type = <0>;
	qcom,emulation = <0>;
	qcom,irq = <255>;
	mdiobus = <&mdio0>;

	pinctrl-0 = <&rt2600_rgmii2_pins>;
	pinctrl-names = "default";

	fixed-link {
		speed = <1000>;
		full-duplex;
	};
};

&gmac2 {
	status = "okay";
	phy-mode = "sgmii";
	qcom,id = <2>;
	qcom,phy_mdio_addr = <0>;
	qcom,poll_required = <0>;
	qcom,rgmii_delay = <0>;
	qcom,phy_mii_type = <1>;
	qcom,emulation = <0>;
	qcom,irq = <258>;
	mdiobus = <&mdio0>;

	fixed-link {
		speed = <1000>;
		full-duplex;
	};
};

&amba {
	sdcc1: sdcc@12400000 {
		status = "okay";
	};
};

&adm_dma {
	status = "okay";
};

&hs_phy_0 {
	status = "okay";
};

&ss_phy_0 {
	status = "okay";
};

&usb3_0 {
	status = "okay";
	pinctrl-0 = <&rt2600_usb0_pwr_en_pins>;
	pinctrl-names = "default";
};

&hs_phy_1 {
	status = "okay";
};

&ss_phy_1 {
	status = "okay";
};

&usb3_1 {
	status = "okay";
	pinctrl-0 = <&rt2600_usb1_pwr_en_pins>;
	pinctrl-names = "default";
};

&pcie0 {
	status = "okay";
	reset-gpio = <&qcom_pinmux 3 GPIO_ACTIVE_LOW>;
	pinctrl-0 = <&pcie0_pins>;
	pinctrl-names = "default";

	bridge@0,0 {
		reg = <0x00000000 0 0 0 0>;
		#address-cells = <3>;
		#size-cells = <2>;
		ranges;

		wifi0: wifi@1,0 {
			compatible = "pci168c,0046";
			reg = <0x00010000 0 0 0 0>;
		};
	};
};

&pcie1 {
	status = "okay";
	reset-gpio = <&qcom_pinmux 48 GPIO_ACTIVE_LOW>;
	pinctrl-0 = <&pcie1_pins>;
	pinctrl-names = "default";
	max-link-speed = <1>;

	bridge@0,0 {
		reg = <0x00000000 0 0 0 0>;
		#address-cells = <3>;
		#size-cells = <2>;
		ranges;

		wifi1: wifi@1,0 {
			compatible = "pci168c,0046";
			reg = <0x00010000 0 0 0 0>;
		};
	};
};

&gsbi4_serial {
	status = "okay";
};
