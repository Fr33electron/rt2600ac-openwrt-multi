From c6c309df076446122c5205613b28af93be240e48 Mon Sep 17 00:00:00 2001
From: Bisect Local <bisect@local>
Date: Sat, 25 Apr 2026 13:14:23 -0500
Subject: [PATCH 992/993] Revert "regulator: of: Refactor of_get_*regulator()
 to decrease indentation"

This reverts commit 401d078eaf2edd605c9121741e166d9326c63677.
---
 drivers/regulator/of_regulator.c | 26 +++++++++++++++-----------
 1 file changed, 15 insertions(+), 11 deletions(-)

diff --git a/drivers/regulator/of_regulator.c b/drivers/regulator/of_regulator.c
index 3f490d81abc2..d5dd7a9e577b 100644
--- a/drivers/regulator/of_regulator.c
+++ b/drivers/regulator/of_regulator.c
@@ -572,12 +572,14 @@ static struct device_node *of_get_child_regulator(struct device_node *parent,
 
 	for_each_child_of_node(parent, child) {
 		regnode = of_parse_phandle(child, prop_name, 0);
-		if (regnode)
-			goto err_node_put;
 
-		regnode = of_get_child_regulator(child, prop_name);
-		if (regnode)
+		if (!regnode) {
+			regnode = of_get_child_regulator(child, prop_name);
+			if (regnode)
+				goto err_node_put;
+		} else {
 			goto err_node_put;
+		}
 	}
 	return NULL;
 
@@ -605,15 +607,17 @@ static struct device_node *of_get_regulator(struct device *dev, const char *supp
 
 	snprintf(prop_name, 64, "%s-supply", supply);
 	regnode = of_parse_phandle(dev->of_node, prop_name, 0);
-	if (regnode)
-		return regnode;
 
-	regnode = of_get_child_regulator(dev->of_node, prop_name);
-	if (regnode)
-		return regnode;
+	if (!regnode) {
+		regnode = of_get_child_regulator(dev->of_node, prop_name);
+		if (regnode)
+			return regnode;
 
-	dev_dbg(dev, "Looking up %s property in node %pOF failed\n", prop_name, dev->of_node);
-	return NULL;
+		dev_dbg(dev, "Looking up %s property in node %pOF failed\n",
+			prop_name, dev->of_node);
+		return NULL;
+	}
+	return regnode;
 }
 
 static struct regulator_dev *of_find_regulator_by_node(struct device_node *np)
-- 
